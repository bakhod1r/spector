// defaultBaseURL is where the document said the API lives. SPECTER_BASE_URL
// overrides it, so the same tests run against a local server, a staging
// deployment, or a mock without being regenerated.
const defaultBaseURL = {{.BaseURL | quote}}

func baseURL() string {
	if v := os.Getenv("SPECTER_BASE_URL"); v != "" {
		return strings.TrimSuffix(v, "/")
	}
	return defaultBaseURL
}

var client = &http.Client{Timeout: 30 * time.Second}

// do sends one request and returns the response with its body already read,
// so every test can inspect the body without worrying about closing it.
type response struct {
	Status      int
	ContentType string
	Body        []byte
}

func do(t *testing.T, method, path string, headers map[string]string, body []byte) response {
	t.Helper()

	var reader io.Reader
	if len(body) > 0 {
		reader = bytes.NewReader(body)
	}
	req, err := http.NewRequest(method, baseURL()+path, reader)
	if err != nil {
		t.Fatalf("%s %s: building the request: %v", method, path, err)
	}
	if len(body) > 0 {
		req.Header.Set("Content-Type", "application/json")
	}
	for k, v := range headers {
		req.Header.Set(k, v)
	}
{{- if .Auth}}
	if v := os.Getenv({{.Auth.Env | quote}}); v != "" {
		req.Header.Set({{.Auth.Header | quote}}, {{.Auth.Prefix | quote}}+v)
	}
{{- end}}

	res, err := client.Do(req)
	if err != nil {
		// A connection error is not a contract failure, and reporting it as
		// one sends the reader looking for a bug in the handler.
		t.Fatalf("%s %s: could not reach %s: %v", method, path, baseURL(), err)
	}
	defer res.Body.Close()

	data, err := io.ReadAll(res.Body)
	if err != nil {
		t.Fatalf("%s %s: reading the response: %v", method, path, err)
	}
	return response{Status: res.StatusCode, ContentType: res.Header.Get("Content-Type"), Body: data}
}

// expectStatus accepts any status the document documents. All of them are
// legitimate answers: a test that demanded 200 would fail on the 404 the
// document itself promises.
func expectStatus(t *testing.T, what string, res response, documented ...int) bool {
	t.Helper()
	for _, code := range documented {
		if res.Status == code {
			return true
		}
	}
	t.Errorf("%s: answered %d, which the document does not list (documented: %v)\n%s",
		what, res.Status, documented, excerpt(res.Body))
	return false
}

// expectJSON checks the response carries the media type the document promised.
// A handler that answers HTML where the document says JSON is broken for every
// generated client, however correct the status code is.
func expectJSON(t *testing.T, what string, res response) bool {
	t.Helper()
	if strings.Contains(res.ContentType, "json") {
		return true
	}
	t.Errorf("%s: Content-Type is %q, want JSON as documented\n%s", what, res.ContentType, excerpt(res.Body))
	return false
}

// ---- shape ----

// schema is the part of JSON Schema worth checking against a live response.
type schema struct {
	Ref        string             `json:"$ref"`
	Type       string             `json:"type"`
	Items      *schema            `json:"items"`
	Properties map[string]*schema `json:"properties"`
	Required   []string           `json:"required"`
	Enum       []any              `json:"enum"`
	AllOf      []*schema          `json:"allOf"`
}

var components map[string]*schema

func init() {
	if err := json.Unmarshal([]byte(componentsJSON), &components); err != nil {
		panic("specter: the generated component schemas do not parse: " + err.Error())
	}
}

// expectShape compares a response body against the schema the document gives
// for it.
//
// What it checks is deliberately narrow: a missing required property, a value
// of the wrong type, and a value outside a documented enum. Those three are
// unambiguous evidence that the document is wrong — anything vaguer produces
// failures a reader cannot act on.
//
// A property the response carries and the document does not is NOT a failure.
// It usually means the API grew and the document has not caught up, which is
// worth knowing but is not a broken contract, so it is reported and passes.
func expectShape(t *testing.T, what string, res response, schemaJSON string) {
	t.Helper()
	if len(res.Body) == 0 {
		t.Errorf("%s: the document describes a response body, but the body is empty", what)
		return
	}

	var s schema
	if err := json.Unmarshal([]byte(schemaJSON), &s); err != nil {
		t.Fatalf("%s: the generated schema does not parse: %v", what, err)
	}
	var value any
	if err := json.Unmarshal(res.Body, &value); err != nil {
		t.Errorf("%s: the response is not JSON: %v\n%s", what, err, excerpt(res.Body))
		return
	}

	for _, problem := range check(&s, value, "response") {
		t.Errorf("%s: %s", what, problem)
	}
	for _, extra := range undocumented(&s, value, "response") {
		t.Logf("%s: %s (the API may have grown past its document)", what, extra)
	}
}

func check(s *schema, value any, path string) []string {
	s = deref(s)
	if s == nil || value == nil {
		// A null where a value was documented is worth reporting, but only
		// when the document actually said something about the shape.
		return nil
	}

	if len(s.Enum) > 0 {
		found := false
		for _, allowed := range s.Enum {
			if fmt.Sprint(allowed) == fmt.Sprint(value) {
				found = true
				break
			}
		}
		if !found {
			return []string{fmt.Sprintf("%s: %v is not one of the documented values %v", path, value, s.Enum)}
		}
	}

	switch s.Type {
	case "array":
		items, ok := value.([]any)
		if !ok {
			return []string{fmt.Sprintf("%s: documented as an array, got %s", path, kindOf(value))}
		}
		var out []string
		for i, item := range items {
			out = append(out, check(s.Items, item, fmt.Sprintf("%s[%d]", path, i))...)
		}
		return out
	case "object", "":
		obj, ok := value.(map[string]any)
		if !ok {
			if s.Type == "" {
				return nil // nothing was documented, so nothing is violated
			}
			return []string{fmt.Sprintf("%s: documented as an object, got %s", path, kindOf(value))}
		}
		var out []string
		for _, name := range s.Required {
			if _, present := obj[name]; !present {
				out = append(out, fmt.Sprintf("%s.%s: documented as required, missing from the response", path, name))
			}
		}
		for name, prop := range s.Properties {
			if v, present := obj[name]; present {
				out = append(out, check(prop, v, path+"."+name)...)
			}
		}
		for _, part := range s.AllOf {
			out = append(out, check(part, value, path)...)
		}
		return out
	case "string":
		if _, ok := value.(string); !ok {
			return []string{fmt.Sprintf("%s: documented as a string, got %s", path, kindOf(value))}
		}
	case "integer", "number":
		if _, ok := value.(float64); !ok {
			return []string{fmt.Sprintf("%s: documented as a %s, got %s", path, s.Type, kindOf(value))}
		}
	case "boolean":
		if _, ok := value.(bool); !ok {
			return []string{fmt.Sprintf("%s: documented as a boolean, got %s", path, kindOf(value))}
		}
	}
	return nil
}

// undocumented lists response properties the document does not mention. They
// are reported rather than failed: the document trailing the API is a real
// finding, but it is not a broken contract.
func undocumented(s *schema, value any, path string) []string {
	s = deref(s)
	if s == nil {
		return nil
	}
	switch v := value.(type) {
	case []any:
		if len(v) == 0 {
			return nil
		}
		// One element is enough: a list is homogeneous, and reporting the same
		// extra field a hundred times helps nobody.
		return undocumented(s.Items, v[0], path+"[0]")
	case map[string]any:
		if len(s.Properties) == 0 && len(s.AllOf) == 0 {
			return nil // nothing was documented, so nothing is missing from it
		}
		known := documentedProperties(s)
		var out []string
		for name := range v {
			if known[name] == nil {
				out = append(out, fmt.Sprintf("%s.%s is in the response but not in the document", path, name))
				continue
			}
			out = append(out, undocumented(known[name], v[name], path+"."+name)...)
		}
		return out
	}
	return nil
}

func documentedProperties(s *schema) map[string]*schema {
	out := map[string]*schema{}
	for name, prop := range s.Properties {
		out[name] = prop
	}
	for _, part := range s.AllOf {
		for name, prop := range documentedProperties(deref(part)) {
			out[name] = prop
		}
	}
	return out
}

// deref follows a $ref into the component schemas.
func deref(s *schema) *schema {
	for i := 0; s != nil && s.Ref != "" && i < 10; i++ {
		s = components[strings.TrimPrefix(s.Ref, "#/components/schemas/")]
	}
	return s
}

func kindOf(value any) string {
	switch value.(type) {
	case nil:
		return "null"
	case bool:
		return "a boolean"
	case float64:
		return "a number"
	case string:
		return "a string"
	case []any:
		return "an array"
	case map[string]any:
		return "an object"
	}
	return "something else"
}

// excerpt keeps a failure message readable when the response is a megabyte of
// JSON.
func excerpt(body []byte) string {
	const limit = 400
	s := strings.TrimSpace(string(body))
	if s == "" {
		return "  (empty body)"
	}
	if len(s) > limit {
		s = s[:limit] + "…"
	}
	return "  body: " + s
}
