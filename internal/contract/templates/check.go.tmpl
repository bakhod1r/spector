// Code generated by specter. Edit freely — it is yours once written.
//
// This file is the support the generated tests lean on: where the API lives,
// how a request is sent, and what it means for a response to match the
// document. contract_test.go holds one test per endpoint and nothing else.

package {{.Package}}

import (
	"bytes"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"os"
	"strings"
