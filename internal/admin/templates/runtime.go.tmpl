		if err := os.MkdirAll(cfg.UploadDir, 0o755); err != nil {
			return fmt.Errorf("admin: upload dir: %w", err)
		}
		// Served from the resolved directory, so a crafted filename cannot
		// escape it.
		g.StaticFS("/uploads", gin.Dir(cfg.UploadDir, false))
	}
