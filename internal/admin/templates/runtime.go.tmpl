// call performs the upstream request.
func (s *server) call(c *gin.Context, method, path string, body any, extra map[string]string) ([]byte, error) {
	var reader io.Reader
	if body != nil {
		data, err := json.Marshal(body)
		if err != nil {
			return nil, err
		}
		reader = bytes.NewReader(data)
	}

	req, err := http.NewRequestWithContext(c.Request.Context(), method,
		strings.TrimSuffix(s.cfg.BaseURL, "/")+path, reader)
	if err != nil {
		return nil, err
	}
	req.Header.Set("Accept", "application/json")
	if body != nil {
		req.Header.Set("Content-Type", "application/json")
	}
	for k, v := range s.cfg.Headers {
		req.Header.Set(k, v)
	}
	for k, v := range extra {
		req.Header.Set(k, v)
	}

	resp, err := s.cfg.Client.Do(req)
	if err != nil {
		return nil, fmt.Errorf("%s %s: %w", method, path, err)
	}
	defer resp.Body.Close()

	data, err := io.ReadAll(io.LimitReader(resp.Body, 8<<20))
	if err != nil {
		return nil, err
	}
	if resp.StatusCode >= 400 {
		// The upstream body is the most useful part of a failure — an RFC 9457
		// problem document says exactly what was wrong with the request.
		msg := strings.TrimSpace(string(data))
		if len(msg) > 400 {
			msg = msg[:400] + "…"
		}
		if msg == "" {
			msg = resp.Status
		}
		return nil, fmt.Errorf("%s %s → %d: %s", method, path, resp.StatusCode, msg)
	}
	return data, nil
}

// fill substitutes the item id into a path template.
func fill(path, param, id string) string {
	if param == "" {
		param = "id"
	}
	return strings.ReplaceAll(path, "{"+param+"}", url.PathEscape(id))
}

// rows normalises a list response into table rows. A list is commonly either a
// bare array or an object wrapping one, so both are accepted rather than
// requiring the API to be shaped a particular way.
func rows(data []byte) []map[string]any {
	var direct []map[string]any
	if err := json.Unmarshal(data, &direct); err == nil {
		return direct
	}
	var envelope map[string]any
	if err := json.Unmarshal(data, &envelope); err != nil {
		return nil
	}
	for _, key := range []string{"items", "data", "results", "list"} {
		if v, ok := envelope[key]; ok {
			if arr, ok := v.([]any); ok {
				out := make([]map[string]any, 0, len(arr))
				for _, e := range arr {
					if m, ok := e.(map[string]any); ok {
						out = append(out, m)
					}
				}
				return out
			}
		}
	}
	// A single object is a list of one rather than an error.
	return []map[string]any{envelope}
}

func object(data []byte) map[string]any {
	var m map[string]any
	if err := json.Unmarshal(data, &m); err != nil {
		return nil
	}
	return m
}

// form builds the request payload from the submitted values, typed according
// to the schema so a number field does not arrive as a string.
func form(c *gin.Context, fields []Field) (map[string]any, error) {
	out := map[string]any{}
	for _, f := range fields {
		raw, present := c.GetPostForm(f.Name)
		if !present || (raw == "" && !f.Required) {
			continue
		}
		switch f.Type {
		case "integer":
			n, err := strconv.ParseInt(raw, 10, 64)
			if err != nil {
				return nil, fmt.Errorf("%s: %q is not a whole number", f.Label, raw)
			}
			out[f.Name] = n
		case "number":
			n, err := strconv.ParseFloat(raw, 64)
			if err != nil {
				return nil, fmt.Errorf("%s: %q is not a number", f.Label, raw)
			}
			out[f.Name] = n
		case "boolean":
			out[f.Name] = raw == "true" || raw == "on" || raw == "1"
		case "object", "array":
			var v any
			if err := json.Unmarshal([]byte(raw), &v); err != nil {
				return nil, fmt.Errorf("%s: %v", f.Label, err)
			}
			out[f.Name] = v
		default:
			out[f.Name] = raw
		}
	}
	return out, nil
}

// formWithUploads builds the payload and stores any uploaded image first, so
// the field carries a URL by the time the API sees it.
func (s *server) formWithUploads(c *gin.Context, fields []Field) (map[string]any, error) {
	payload, err := form(c, fields)
	if err != nil {
		return nil, err
	}
	for _, f := range fields {
		if !f.Image {
			continue
		}
		fh, ferr := c.FormFile(f.Name + "__file")
		if ferr != nil || fh == nil {
			continue // no new file; whatever the text field held stands
		}
		url, serr := s.storeUpload(c, fh)
		if serr != nil {
			return nil, fmt.Errorf("%s: %w", f.Label, serr)
		}
		payload[f.Name] = url
	}
	return payload, nil
}

// storeUpload writes an uploaded image and returns the URL it is served at.
func (s *server) storeUpload(c *gin.Context, fh *multipart.FileHeader) (string, error) {
	if s.cfg.UploadDir == "" {
		return "", fmt.Errorf("uploads are not configured; set UploadDir or paste a URL instead")
	}
	if fh.Size > s.cfg.MaxUploadBytes {
		return "", fmt.Errorf("file is %d bytes, over the %d byte limit", fh.Size, s.cfg.MaxUploadBytes)
	}

	// The extension is taken from the client's filename, so it is validated
	// against a list rather than trusted: an uploaded .html served back from
	// the panel's own origin would be a stored XSS.
	ext := strings.ToLower(filepath.Ext(fh.Filename))
	if !allowedImageExt[ext] {
		return "", fmt.Errorf("%q is not an allowed image type", ext)
	}

	// A random name, never the client's. A supplied name could collide with an
	// existing file or contain path separators.
	var buf [16]byte
	if _, err := rand.Read(buf[:]); err != nil {
		return "", err
	}
	name := fmt.Sprintf("%x%s", buf, ext)

	if err := c.SaveUploadedFile(fh, filepath.Join(s.cfg.UploadDir, name)); err != nil {
		return "", err
	}
	if s.cfg.PublicURL != "" {
		return strings.TrimSuffix(s.cfg.PublicURL, "/") + "/" + name, nil
	}
	return s.cfg.Prefix + "/uploads/" + name, nil
}

// allowedImageExt is what the panel will store and serve back.
var allowedImageExt = map[string]bool{
	".png": true, ".jpg": true, ".jpeg": true, ".gif": true, ".webp": true, ".svg": false,
}

// raw echoes the submitted values back so a rejected form is not blanked.
func raw(c *gin.Context, fields []Field) map[string]any {
	out := map[string]any{}
	for _, f := range fields {
		if v, ok := c.GetPostForm(f.Name); ok {
			out[f.Name] = v
		}
	}
	return out
}

var funcs = template.FuncMap{
	// field looks up a column's metadata by its JSON key. An unknown key
	// yields a zero Field, so a response property the spec did not describe
	// still renders as plain text rather than failing the page.
	"field": func(r Resource, key string) Field {
		for _, f := range r.Fields {
			if f.Name == key {
				return f
			}
		}
		for _, f := range r.Form {
			if f.Name == key {
				return f
			}
		}
		return Field{Name: key}
	},
	"cell":  func(row map[string]any, key string) string { return text(row[key]) },
	"cellv": text,
	"label": label,
	// value renders a form input's current value, which is not the same job as
	// rendering a table cell: a cell summarises ("2 item(s)") but an input has
	// to round-trip, so a nested value is written as the JSON that will be
	// parsed back on submit.
	"value": func(item map[string]any, key string) string {
		if item == nil {
			return ""
		}
		switch v := item[key].(type) {
		case nil:
			return ""
		case map[string]any, []any:
			data, err := json.Marshal(v)
			if err != nil {
				return ""
			}
			return string(data)
		default:
			return text(v)
		}
	},
	"scalar": func(v any) bool {
		switch v.(type) {
		case map[string]any, []any:
			return false
		}
		return true
	},
	"isMap":  func(v any) bool { _, ok := v.(map[string]any); return ok },
	"isList": func(v any) bool { _, ok := v.([]any); return ok },
	"items":  func(v any) []any { s, _ := v.([]any); return s },
	"inc":    func(i int) int { return i + 1 },
	// entries returns a map's key/value pairs in a stable order, so a detail
	// view does not reshuffle its fields between requests.
	"entries": func(v any) []entry {
		m, ok := v.(map[string]any)
		if !ok {
			return nil
		}
		keys := make([]string, 0, len(m))
		for k := range m {
			keys = append(keys, k)
		}
		sort.Strings(keys)
		out := make([]entry, len(keys))
		for i, k := range keys {
			out[i] = entry{Key: k, Value: m[k]}
		}
		return out
	},
	"pretty": func(v any) string {
		data, err := json.MarshalIndent(v, "", "  ")
		if err != nil {
			return fmt.Sprint(v)
		}
		return string(data)
	},
	"rowID": func(r Resource, row map[string]any) string {
		// The id the item endpoint needs. The path parameter's own name is the
		// best guess, then the conventional ones.
		for _, key := range append([]string{r.IDParam}, "id", "ID", "uuid", "_id") {
			if v, ok := row[key]; ok && text(v) != "" {
				return text(v)
			}
		}
		for _, f := range r.Fields {
			if f.Primary {
				if v, ok := row[f.Name]; ok {
					return text(v)
				}
			}
		}
		return ""
	},
	"inputType": func(f Field) string {
		switch {
		case f.Format == "email":
			return "email"
		case f.Format == "uri" || f.Format == "url":
			return "url"
		case f.Format == "date":
			return "date"
		case f.Format == "date-time":
			return "datetime-local"
		case f.Format == "password":
			return "password"
		case f.Type == "integer" || f.Type == "number":
			return "number"
		}
		return "text"
	},
	"sorted": func(m map[string]any) []string {
		keys := make([]string, 0, len(m))
		for k := range m {
			keys = append(keys, k)
		}
		sort.Strings(keys)
		return keys
	},
}

// text renders a JSON value as one line of table text.
func text(v any) string {
	switch t := v.(type) {
	case nil:
		return ""
	case string:
		return t
	case bool:
		return strconv.FormatBool(t)
	case float64:
		// JSON has one number type; whole values should not read as "3.000000".
		if t == float64(int64(t)) {
			return strconv.FormatInt(int64(t), 10)
		}
		return strconv.FormatFloat(t, 'f', -1, 64)
	case []any:
		return fmt.Sprintf("%d item(s)", len(t))
	case map[string]any:
		return "{…}"
	}
	return fmt.Sprint(v)
}

func label(s string) string {
	s = strings.NewReplacer("_", " ", "-", " ").Replace(s)
	if s == "" {
		return ""
	}
	return strings.ToUpper(s[:1]) + s[1:]
}
