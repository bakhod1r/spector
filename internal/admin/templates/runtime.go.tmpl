	g.POST("/:resource/new", s.submitCreate)
	g.GET("/:resource/:id", s.detail)
	g.GET("/:resource/:id/edit", s.edit)
	g.POST("/:resource/:id/edit", s.submitEdit)
	g.POST("/:resource/:id/delete", s.remove)
