# Shop example configuration, read by oneenv (see config.go).
# Copy to .env.local to override without touching this file.

PORT=8080
GRPC_ADDR=:50051
SHOP_DB=shop.db

# Console (Specter docs)
SPECTER_BASE_PATH=/docs
# SPECTER_KEY=change-me        # uncomment to gate the console behind ?key=
ADMIN_URL=http://localhost:9090/admin
